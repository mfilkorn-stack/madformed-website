# =============================================================================
# madformed-website — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env or .env.local — they are in .gitignore.
# All values marked REQUIRED must be set before starting the server.
# Values marked OPTIONAL have a safe default and can be omitted.
# =============================================================================

# --- Server -------------------------------------------------------------------

# Port the Express server listens on (OPTIONAL, default: 5000)
PORT=5000

# Node environment: development | production (REQUIRED at runtime)
NODE_ENV=development

# --- Database -----------------------------------------------------------------

# PostgreSQL connection URL (REQUIRED for db:push / Drizzle migrations)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Note: The server uses JSON-file-based storage at runtime; DATABASE_URL is
# only needed when running `npm run db:push` (schema migrations).
DATABASE_URL=postgresql://postgres:password@localhost:5432/madformed

# --- Site / SEO ---------------------------------------------------------------

# Canonical base URL injected into sitemap.xml, robots.txt, llms.txt
# (OPTIONAL, default: https://madformed.de)
SITE_URL=https://madformed.de

# --- Replit-specific (optional — only needed on Replit) -----------------------

# Set automatically by Replit; enables dev-only UI plugins in vite.config.ts.
# Leave unset in all non-Replit environments.
# REPL_ID=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=
# REPLIT_CONNECTORS_HOSTNAME=
