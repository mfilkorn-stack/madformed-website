# npmrc — madformed-website
# Enforces deterministic installs and security best practices.

# Use only the official npm registry (no accidental proxies)
registry=https://registry.npmjs.org/

# Require lockfile integrity — `npm ci` will fail if lock file is out of sync
# (This is the default for `npm ci`; stated explicitly for documentation.)
# package-lock-only=false

# Disable funding messages in CI output
fund=false

# Disable update notifications in CI output
update-notifier=false

# Always save exact versions when adding packages (no ^ or ~ drift)
save-exact=false

# Emit audit output as structured data (parsed by CI audit step)
audit=true

# Disable package telemetry
no-update-notifier=true
